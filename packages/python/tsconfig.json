{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "*": [
        "./*"
      ],
      "@codefortify/olloweditor": [
        "./types/index.d.ts"
      ]
    }
  },
  "include": [
    "tests/types/**/*.ts"
  ]
}
