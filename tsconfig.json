{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "./dist/types",
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "examples",
    "dist",
    "node_modules"
  ]
}
